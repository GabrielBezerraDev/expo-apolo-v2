{
  "expo": {
    "name": "ValorlogOcrExpo",
    "slug": "valorlog-ocr-expo",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.valorlogocrexpo",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permita que o Valorlog use a câmera para escanear etiquetas."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Permita que o Valorlog use a câmera para escanear etiquetas."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-sqlite"
    ]
  }
}
