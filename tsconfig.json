{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "lib": ["esnext", "dom"],
    "baseUrl": ".",
    "paths": {
      "@application/*": ["src/application/*"],
      "@assets/*": ["src/assets/*"],
      "@config/*": ["src/config/*"],
      "@features/*": ["src/features/*"],
      "@navigation/*": ["src/navigation/*"],
      "@shared/*": ["src/shared/*"],
      "@styles/*": ["src/styles/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
