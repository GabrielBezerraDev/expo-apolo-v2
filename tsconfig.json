{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "lib": ["esnext", "dom"],
    "paths": {
      "@application/*": ["./src/application/*"],
      "@assets/*": ["./src/assets/*"],
      "@config/*": ["./src/config/*"],
      "@features/*": ["./src/features/*"],
      "@navigation/*": ["./src/navigation/*"],
      "@shared/*": ["./src/shared/*"],
      "@styles/*": ["src/shared/styles/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
